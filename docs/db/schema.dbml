Table users {
  id int pk
  name varchar 
  email varchar 
  email_verified_at datetime
  password_hash varchar 
  role varchar 
  expires_at datetime
  remember_token varchar
  created_at datetime
  updated_at datetime
}

Table tracks {
  id int pk
  name varchar 
  created_at datetime
  updated_at datetime
}


Table cohorts {
  track_id int 
  id int pk
  number int 
  is_active tinyint 
  created_at datetime
  updated_at datetime
}
Ref: cohorts.track_id > tracks.id

Table courses {
  cohort_id int 
  id int pk
  name varchar 
  created_at datetime
  updated_at datetime
}
Ref: courses.cohort_id > cohorts.id

Table tags {
  id int pk
  tag varchar 
  created_at datetime
  updated_at datetime
}


Table student_profiles {
  id int pk
  user_id int 
  notes text 
  attendance_balance int 
  created_at datetime
  updated_at datetime
  cohort_id int 
}
Ref: student_profiles.cohort_id > cohorts.id
Ref: student_profiles.user_id > users.id

Table students_tags {
  id int pk
  tag_id int 
  student_id int 
  created_at datetime
  updated_at datetime
}
Ref: students_tags.tag_id > tags.id
Ref: students_tags.student_id > student_profiles.id

Table staff_profiles {
  user_id int 
  id int pk
  compensation_type varchar 
  hourly_rate numeric 
  created_at datetime
  updated_at datetime
}
Ref: staff_profiles.user_id > users.id

Table lab_groups {
  cohort_id int 
  id int pk
  name varchar 
  created_at datetime
  updated_at datetime
}
Ref: lab_groups.cohort_id > cohorts.id

Table labs {
  id int pk
  course_id int 
  lab_group_id int 
  name varchar 
  created_at datetime
  updated_at datetime
}
Ref: labs.course_id > courses.id
Ref: labs.lab_group_id > lab_groups.id

Table lab_group_users {
  id int pk
  lab_group_id int 
  student_id int 
  created_at datetime
  updated_at datetime
}
Ref: lab_group_users.student_id > student_profiles.id
Ref: lab_group_users.lab_group_id > lab_groups.id

Table business_sessions {
  id int pk
  name varchar 
  created_at datetime
  updated_at datetime
}


Table business_sessions_cohorts {
  id int pk
  business_session_id int 
  cohort_id int 
  created_at datetime
  updated_at datetime
}
Ref: business_sessions_cohorts.cohort_id > cohorts.id
Ref: business_sessions_cohorts.business_session_id > business_sessions.id

Table courses_deliverables {
  id int pk
  course_id int 
  type varchar 
  name varchar 
  max_score int 
  course_weight int 
  due_date datetime
  created_at datetime
  updated_at datetime
}
Ref: courses_deliverables.course_id > courses.id

Table submissions {
  id int pk
  deliverable_id int 
  student_id int 
  submission_type varchar 
  submission_path varchar 
  raw_score numeric 
  override_score numeric 
  override_note text 
  created_at datetime
  updated_at datetime
}
Ref: submissions.student_id > student_profiles.id
Ref: submissions.deliverable_id > courses_deliverables.id

Table engagements {
  id int pk
  instructor_id int 
  type varchar 
  starts_at datetime
  ends_at datetime
  scheduled_hours numeric 
  created_at datetime
  updated_at datetime
  engageable_id int 
}
Ref: engagements.instructor_id > staff_profiles.id
Ref: engagements.engageable_id > courses.id
Ref: engagements.engageable_id > labs.id
Ref: engagements.engageable_id > business_sessions.id

Table attendance_records {
  id int pk
  student_id int 
  engagement_id int 
  arrived_at datetime
  left_at datetime
  created_at datetime
  updated_at datetime
}
Ref: attendance_records.student_id > student_profiles.id
Ref: attendance_records.engagement_id > engagements.id

Table excuse_requests {
  id int pk
  attendance_id int 
  reason text 
  attachment_path varchar 
  status varchar 
  created_at datetime
  updated_at datetime
}
Ref: excuse_requests.attendance_id > attendance_records.id

Table announcements {
  id int pk
  cohort_id int 
  author_id int
  title varchar 
  body text 
  created_at datetime
  updated_at datetime
}
Ref: announcements.cohort_id > cohorts.id
Ref: announcements.author_id > staff_profiles.id
